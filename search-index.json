---
layout: null
permalink: /search-index.json
sitemap: false
---
[
{% for post in site.posts %}
  {% assign body = post.content | split: '<script' | first | strip_html | normalize_whitespace %}
  {
    "id": {{ forloop.index0 }},
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "date": {{ post.date | date: "%Y-%m-%d" | jsonify }},
    "dateh": {{ post.date | date: "%-d %B %Y" | jsonify }},
    "author": {{ post.author | default: "" | jsonify }},
    "category": {{ post.category | default: "" | jsonify }},
    "tags": {{ post.tags | join: " " | jsonify }},
    "excerpt": {{ post.excerpt | strip_html | normalize_whitespace | jsonify }},
    "content": {{ body | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
